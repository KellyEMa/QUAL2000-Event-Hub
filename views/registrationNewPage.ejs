<%- include("partials/head", { pageTitle, shellClass: "site-shell-public" }) %>
<%- include("partials/publicNav") %>

<section class="page-header">
  <div class="shell-section">
    <div class="page-header-grid">
      <span class="eyebrow">Registration form</span>
      <h1 class="page-title">Reserve your place for <%= event.title %>.</h1>
      <p class="page-copy">
        Submit your name, email address, and ticket count. Event Hub will only accept
        the request when the event still has enough open slots.
      </p>
    </div>
  </div>
</section>

<section class="utility-section">
  <div class="shell-section">
    <div class="detail-grid">
      <div class="detail-panel">
        <span class="eyebrow">Event snapshot</span>
        <h2 class="detail-title"><%= event.title %></h2>
        <p class="detail-copy"><%= event.description %></p>

        <div class="detail-list">
          <div class="detail-list-item">
            <span class="detail-label">Date</span>
            <span class="detail-value"><%= formatDate(event.date) %></span>
          </div>
          <div class="detail-list-item">
            <span class="detail-label">Location</span>
            <span class="detail-value"><%= event.location %></span>
          </div>
          <div class="detail-list-item">
            <span class="detail-label">Available Slots</span>
            <span class="detail-value"><%= event.availableSlots %></span>
          </div>
        </div>
      </div>

      <div class="admin-form-shell">
        <%- include("partials/message", { message: "", errorMessage }) %>

        <form action="/events/registrations" method="POST">
          <input type="hidden" name="eventId" value="<%= event._id %>" />

          <div class="form-grid">
            <div class="form-group">
              <label class="label" for="attendeeName">Attendee Name</label>
              <input
                class="input"
                id="attendeeName"
                name="attendeeName"
                type="text"
                required
                value="<%= formData.attendeeName %>"
              />
            </div>

            <div class="form-group">
              <label class="label" for="attendeeEmail">Attendee Email</label>
              <input
                class="input"
                id="attendeeEmail"
                name="attendeeEmail"
                type="email"
                required
                value="<%= formData.attendeeEmail %>"
              />
            </div>

            <div class="form-group form-group-full">
              <label class="label" for="ticketCount">Ticket Count</label>
              <input
                class="input"
                id="ticketCount"
                name="ticketCount"
                type="number"
                min="1"
                max="<%= event.availableSlots %>"
                required
                value="<%= formData.ticketCount %>"
              />
            </div>
          </div>

          <div class="form-actions">
            <button class="button-primary" type="submit">Create Registration</button>
            <a class="button-secondary" href="/events/<%= event._id %>">Back To Event</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<%- include("partials/footer") %>
