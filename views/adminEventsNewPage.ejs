<%- include("partials/head", { pageTitle, shellClass: "site-shell-admin" }) %>
<%- include("partials/adminNav") %>

<section class="utility-section">
  <div class="shell-section">
    <div class="admin-header">
      <span class="eyebrow">Create event</span>
      <h1 class="admin-title">Add a new event to the public calendar.</h1>
      <p class="admin-subtitle">
        Complete every field so the event can appear on the public pages with the
        correct date, image, and available capacity.
      </p>
    </div>

    <div class="admin-form-shell">
      <%- include("partials/message", { message: "", errorMessage }) %>

      <form action="/admin/events" method="POST">
        <div class="form-grid">
          <div class="form-group">
            <label class="label" for="title">Event Title</label>
            <input class="input" id="title" name="title" type="text" required value="<%= formData.title %>" />
          </div>

          <div class="form-group">
            <label class="label" for="date">Event Date</label>
            <input class="input" id="date" name="date" type="date" required value="<%= formData.date %>" />
          </div>

          <div class="form-group">
            <label class="label" for="location">Location</label>
            <input class="input" id="location" name="location" type="text" required value="<%= formData.location %>" />
          </div>

          <div class="form-group">
            <label class="label" for="category">Category</label>
            <input class="input" id="category" name="category" type="text" required value="<%= formData.category %>" />
          </div>

          <div class="form-group form-group-full">
            <label class="label" for="image">Image URL</label>
            <input class="input" id="image" name="image" type="url" required value="<%= formData.image %>" />
          </div>

          <div class="form-group form-group-full">
            <label class="label" for="description">Description</label>
            <textarea class="textarea" id="description" name="description" required><%= formData.description %></textarea>
          </div>

          <div class="form-group form-group-full">
            <label class="label" for="availableSlots">Available Slots</label>
            <input
              class="input"
              id="availableSlots"
              name="availableSlots"
              type="number"
              min="0"
              required
              value="<%= formData.availableSlots %>"
            />
          </div>
        </div>

        <div class="form-actions">
          <button class="button-primary" type="submit">Create Event</button>
          <a class="button-secondary" href="/admin/events">Back To Dashboard</a>
        </div>
      </form>
    </div>
  </div>
</section>

<%- include("partials/footer") %>
